# ============================================================
# Agent Loop — 多轮工具调用（意图识别 + 参数提取 + 工具调度）
# ============================================================
LLM_TOOL_USE_API_KEY=sk-692999fa8f69458cbce83ff294ad003c
LLM_TOOL_USE_BASE_URL=https://api.deepseek.com
LLM_MODEL_TOOL_USE=deepseek-v4-flash
LLM_MAX_TOKENS_TOOL_USE=16384
LLM_THINKING_TOOL_USE=disabled

# 模型升级：Agent Loop 超过 N 轮后切换更强模型（留空则不升级，可跨厂商）
LLM_ESCALATION_API_KEY=
LLM_ESCALATION_BASE_URL=
LLM_ESCALATION_MODEL=deepseek-v4-pro
LLM_ESCALATION_AFTER_ROUNDS=6
LLM_MAX_TOKENS_ESCALATION=16384
LLM_THINKING_ESCALATION=disabled

# ============================================================
# 参数提取 — 伤害计算 LLM#2 / 阈值计算 LLM#2t（独立配置）
# ============================================================
LLM_CALC_API_KEY=sk-692999fa8f69458cbce83ff294ad003c
LLM_CALC_BASE_URL=https://api.deepseek.com
LLM_MODEL_CALC=deepseek-v4-pro
LLM_MAX_TOKENS_CALC=16384
LLM_THINKING_CALC=disabled

# ============================================================
# 结果总结 — 查询结果 / 伤害结果 / 阈值结果（共用 summary client）
# ============================================================
LLM_SUMMARY_API_KEY=sk-692999fa8f69458cbce83ff294ad003c
LLM_SUMMARY_BASE_URL=https://api.deepseek.com
LLM_MODEL_SUMMARY=deepseek-v4-flash
LLM_MAX_TOKENS_SUMMARY=16384
LLM_THINKING_QUERY_SUMMARY=enabled
LLM_THINKING_DAMAGE_SUMMARY=disabled
LLM_THINKING_THRESHOLD_SUMMARY=disabled

# ============================================================
# Wiki 同步分析 — sync_detector.py（数据库值 vs wiki 全文对比）
# ============================================================
LLM_SYNC_API_KEY=tp-cv499o5ocz6c3jrv081jgcfo9xo6l33iscy32q643brmmt4b
LLM_SYNC_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL_SYNC=mimo-v2.5

# ============================================================
# 数据库路径（可选，默认为 ../pokemon_data/pokemonData.db）

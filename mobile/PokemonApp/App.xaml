<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PokemonApp"
             xmlns:conv="clr-namespace:PokemonApp.Converters"
             x:Class="PokemonApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:StringToBoolConverter x:Key="StringToBoolConverter" />
            <conv:BusyToButtonTextConverter x:Key="BusyToButtonTextConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

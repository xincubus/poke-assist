<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonApp.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="35,80,35,35" VerticalOptions="Center">

            <Image Source="timburr.png" HeightRequest="120" WidthRequest="120"
                   HorizontalOptions="Center" />

            <Label Text="注册新账号" FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}" />

            <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 10" Padding="12,4">
                <Entry Placeholder="用户名" Text="{Binding Username}" FontSize="16" />
            </Border>

            <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 10" Padding="12,4">
                <Entry Placeholder="密码" Text="{Binding Password}"
                       IsPassword="True" FontSize="16" />
            </Border>

            <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 10" Padding="12,4">
                <Entry Placeholder="确认密码" Text="{Binding ConfirmPassword}"
                       IsPassword="True" FontSize="16" />
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" FontSize="14"
                   HorizontalOptions="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

            <Button Text="注册" Command="{Binding RegisterCommand}"
                    BackgroundColor="#5B75F5" TextColor="White"
                    FontSize="16" HeightRequest="48" CornerRadius="10" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="已有账号？" TextColor="{AppThemeBinding Light=#999, Dark=#AAAAAA}" FontSize="14" VerticalOptions="Center" />
                <Label Text="去登录" TextColor="#5B75F5" FontSize="14" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#5B75F5" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

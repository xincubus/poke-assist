<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonApp.Views.TeamListPage"
             Title="队伍"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1f1f1f}">

    <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,*" Padding="16,10" BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
            <Button Text="宝可梦" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#333}"
                    TextColor="{AppThemeBinding Light=#666, Dark=#AAAAAA}"
                    CornerRadius="8" FontSize="14" Clicked="GoToPokemon" />
            <Button Grid.Column="1" Text="队伍" BackgroundColor="#5B75F5" TextColor="White"
                    CornerRadius="8" FontSize="14" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Teams}" Margin="10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}"
                            Stroke="Transparent" StrokeShape="RoundRectangle 8"
                            Padding="10" HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTeamTapped" />
                            <TapGestureRecognizer Tapped="OnTeamLongPressed" NumberOfTapsRequired="2" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" />
                            <Label Text="{Binding MemberCount, StringFormat='成员：{0}/6'}"
                                   FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#AAA}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="还没有队伍" FontSize="16"
                           TextColor="{AppThemeBinding Light=#999, Dark=#AAAAAA}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- FAB 新建按钮 -->
        <Button Grid.Row="1" Text="+" FontSize="24" TextColor="White"
                BackgroundColor="#5B75F5" CornerRadius="28"
                WidthRequest="56" HeightRequest="56"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,20"
                Clicked="OnAddClicked" />
    </Grid>
</ContentPage>

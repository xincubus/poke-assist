<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonApp.Views.SettingsPage"
             Title="设置"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1f1f1f}">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="20">

            <!-- 用户信息卡片 -->
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 12" Padding="20">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Ellipse Fill="#5B75F5" WidthRequest="60" HeightRequest="60"
                             HorizontalOptions="Center" />
                    <Label x:Name="UsernameLabel" Text="训练家" FontSize="18"
                           FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- 设置项 -->
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}" Stroke="Transparent"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="16">
                    <Label Text="服务器地址" FontSize="14" TextColor="{AppThemeBinding Light=#999, Dark=#AAAAAA}" />
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 8" Padding="10,6">
                        <Entry x:Name="ServerUrlEntry" FontSize="14"
                               Placeholder="http://10.0.2.2:8000" />
                    </Border>

                    <Label Text="对话模型（意图识别 / 结果总结）" FontSize="14" TextColor="{AppThemeBinding Light=#999, Dark=#AAAAAA}" />
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 8" Padding="4,0">
                        <Picker x:Name="ModelPicker" FontSize="14">
                            <Picker.Items>
                                <x:String>服务器默认</x:String>
                                <x:String>Haiku（快速）</x:String>
                                <x:String>Sonnet（精准）</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>

                    <Label Text="计算模型（伤害参数提取）" FontSize="14" TextColor="{AppThemeBinding Light=#999, Dark=#AAAAAA}" />
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" StrokeShape="RoundRectangle 8" Padding="4,0">
                        <Picker x:Name="ToolModelPicker" FontSize="14">
                            <Picker.Items>
                                <x:String>服务器默认</x:String>
                                <x:String>Haiku（快速）</x:String>
                                <x:String>Sonnet（精准）</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- 退出登录 -->
            <Button Text="退出登录" BackgroundColor="#FF4444" TextColor="White"
                    CornerRadius="10" HeightRequest="48" FontSize="16"
                    Clicked="OnLogout" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

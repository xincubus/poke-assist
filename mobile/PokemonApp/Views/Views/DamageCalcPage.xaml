<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonApp.Views.DamageCalcPage"
             Title="伤害计算器"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1f1f1f}">

    <Grid RowDefinitions="Auto,*">
        <!-- 顶部栏 -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2d2d2d}"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                StrokeThickness="0,0,0,1"
                Padding="8,8">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                        FontSize="20"
                        Padding="8,0"
                        WidthRequest="44" HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="伤害计算器"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                       VerticalOptions="Center"
                       Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- WebView -->
        <WebView x:Name="CalcWebView"
                 Grid.Row="1" />
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PokemonApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PokemonApp.Views"
    Title="搬运小匠"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1f1f1f}">

    <!-- 自定义侧边栏内容 -->
    <Shell.FlyoutContent>
        <ScrollView BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1f1f1f}">
            <VerticalStackLayout Spacing="0">
                <!-- 主菜单项 -->
                <CollectionView ItemsSource="{Binding MenuItems}"
                               SelectionMode="Single"
                               SelectionChanged="OnMenuItemSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="20,15" BackgroundColor="Transparent">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuItemTapped" />
                                </Grid.GestureRecognizers>
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- 分隔线 -->
                <BoxView HeightRequest="1"
                         Color="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                         Margin="0,10" />

                <!-- 历史对话标题 -->
                <Label Text="历史对话"
                       FontSize="14"
                       FontAttributes="Bold"
                       Margin="20,10,20,10"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                <!-- 历史对话列表 -->
                <CollectionView ItemsSource="{Binding ChatHistories}"
                               SelectionMode="Single"
                               SelectionChanged="OnChatHistorySelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="20,12" BackgroundColor="Transparent"
                                  ColumnDefinitions="Auto,*">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnChatHistoryTapped" />
                                    <PointerGestureRecognizer PointerPressed="OnChatHistoryPointerPressed"
                                                              PointerReleased="OnChatHistoryPointerReleased" />
                                </Grid.GestureRecognizers>
                                <!-- 置顶图标 -->
                                <Label Grid.Column="0"
                                       Text="📌"
                                       FontSize="11"
                                       IsVisible="{Binding IsPinned}"
                                       VerticalOptions="Center"
                                       Margin="0,0,4,0" />
                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Shell.FlyoutContent>

    <!-- 登录/注册（无侧边栏） -->
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}"
                  Shell.FlyoutBehavior="Disabled" />
    <ShellContent Route="register" ContentTemplate="{DataTemplate views:RegisterPage}"
                  Shell.FlyoutBehavior="Disabled" />

    <!-- 主界面页面 -->
    <ShellContent Route="chat" ContentTemplate="{DataTemplate views:ChatPage}" />
    <ShellContent Route="pokemon" ContentTemplate="{DataTemplate views:PokemonListPage}" />
    <ShellContent Route="teams" ContentTemplate="{DataTemplate views:TeamListPage}" />
    <ShellContent Route="home" ContentTemplate="{DataTemplate views:HomePage}" />
    <ShellContent Route="damagecalctab" ContentTemplate="{DataTemplate views:DamageCalcPage}" />
    <ShellContent Route="settings" ContentTemplate="{DataTemplate views:SettingsPage}" />

</Shell>
